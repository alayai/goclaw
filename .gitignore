# If you prefer the allow list template instead of the deny list, see community template:
# https://github.com/github/gitignore/blob/main/community/Golang/Go.AllowList.gitignore
#
# Binaries for programs and plugins
*.exe
*.exe~
*.dll
*.so
*.dylib

# Test binary, built with `go test -c`
*.test

# Code coverage profiles and other test artifacts
*.out
coverage.*
*.coverprofile
profile.cov

# Dependency directories (remove the comment below to include it)
# vendor/

# Go workspace file
go.work
go.work.sum

# env file
.env

# Windows reserved name (accidental `echo ... > nul` in repo root breaks `git add .`)
/nul

# Editor/IDE
# .idea/
# .vscode/
.DS_Store

dist/
.gocache/

# Vite UI bundle for //go:embed (gateway/ui.go); build with scripts/build-full.ps1 or copy ui/dist here
gateway/ui_dist/**
!gateway/ui_dist/placeholder-for-embed.txt

# Backend Go binary / local build output (make build, scripts/build-full.ps1, manual go build -o …)
/goclaw
/goclaw.exe
/goclaw_*
/bin/

config.json
google_search_results.json

.history

node_modules/
.claude/

# Rust / Tauri
# Compiled files
*.o
*.so
*.rlib
*.dll

# Rust target directory
src-tauri/target/

# Rust backup files
**/*.rs.bk
*.pdb

# Cargo lock for library projects (keep for applications)
# src-tauri/Cargo.lock

# Sidecar binaries (built during release)
src-tauri/binaries/

# Tauri Wix output
src-tauri/WixTools/
